    "@types/node": "^22.15.29",
    "@types/sql.js": "^1.4.11",
    "electron": "^35.2.1",
    "electron-vite": "^3.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
